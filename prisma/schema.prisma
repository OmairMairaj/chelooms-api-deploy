// prisma/schema.prisma

// 1. Generator
generator client {
  provider = "prisma-client-js"
}

// 2. Datasource
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---

enum UserRole {
  Registered
  Administrator
  Inventory_Manager
}

enum AuthProviderType {
  Email
  Mobile
  Google
  Microsoft
  Apple
  Facebook
}

enum AuthAttemptType {
  login
  register
  otp_verify
  email_verify
}

enum AuthStatus {
  success
  failed
  blocked
}

enum InventoryType {
  FABRIC
  EMBELLISHMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STOCK_ADJUSTMENT
  STOCK_OVERRIDE
}

enum OperationalStatus {
  checkout_draft // SHOPPING CART
  checkout_abandoned
  pending_payment
  paid_processing
  in_production
  quality_check
  ready_to_ship
  shipped
  delivered
  cancelled
  returned
}

enum PaymentStatus {
  unpaid
  paid
  failed
  refunded
  partially_refunded
}

enum ItemType {
  fabric
  embellishment
  design_bundle
}

enum PaymentMethod {
  COD // Cash on Delivery
  CREDIT_CARD
  BANK_TRANSFER
}

// Sizing
enum MeasurementUnit {
  Inches
  CM
}

enum SizingMethod {
  Standard_Preset
  Jute_Fit_Custom
}

// ==========================================
// 1. AUTH & USER MODELS
// ==========================================

model User {
  user_id       String  @id @default(uuid()) @db.Uuid
  first_name    String  @db.VarChar(50)
  last_name     String  @db.VarChar(50)
  email         String? @unique @db.VarChar(255)
  mobile_number String? @unique @db.VarChar(20)
  password_hash String? @db.VarChar(255)

  // Verification Status
  is_email_verified  Boolean @default(false)
  is_mobile_verified Boolean @default(false)

  // Role & Profile
  role                UserRole @default(Registered)
  profile_picture_url String?
  preferred_language  String   @default("English") @db.VarChar(10)

  // Security
  failed_login_attempts Int       @default(0)
  locked_until          DateTime? @db.Timestamptz

  // Timestamps
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz // Soft Delete

  // Relations
  social_identities  SocialIdentity[]
  sessions           UserSession[]
  verification_codes VerificationCode[]

  // New Relations for Order Module
  addresses       UserAddress[]
  orders          Order[]
  sizing_profiles UserSizingProfile[]
  inventory_logs  InventoryAuditLog[] // Relation for Admin actions
  savedDesigns  SavedDesign[]

  @@map("users")
}

model SocialIdentity {
  identity_id  String           @id @default(uuid()) @db.Uuid
  user_id      String           @db.Uuid
  provider     AuthProviderType
  provider_uid String           @db.VarChar(255)
  linked_at    DateTime         @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([provider, provider_uid])
  @@map("social_identities")
}

model VerificationCode {
  code_id    String   @id @default(uuid()) @db.Uuid
  identifier String   @db.VarChar(255)
  code       String   @db.VarChar(10)
  type       String   @db.VarChar(20)
  expires_at DateTime @db.Timestamptz
  is_used    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  user_id String? @db.Uuid
  user    User?   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("verification_codes")
}

model UserSession {
  session_id         String   @id @default(uuid()) @db.Uuid
  user_id            String   @db.Uuid
  refresh_token_hash String   @db.VarChar(255)
  device_info        String?
  ip_address         String?  @db.Inet
  expires_at         DateTime @db.Timestamptz
  last_active        DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_sessions")
}

model AuthAuditLog {
  id             BigInt          @id @default(autoincrement())
  identifier     String          @db.VarChar(255)
  attempt_type   AuthAttemptType
  status         AuthStatus
  failure_reason String?         @db.VarChar(255)
  ip_address     String?         @db.VarChar(45)
  user_agent     String?         @db.Text
  created_at     DateTime        @default(now()) @db.Timestamptz

  @@map("auth_audit_logs")
}

// ==========================================
// 2. INVENTORY MODELS
// ==========================================

model InventoryCategory {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  slug        String?         @unique
  type        InventoryType
  description String?
  items       InventoryItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("inventory_categories")
}

model InventoryItem {
  id         String            @id @default(uuid())
  categoryId Int
  category   InventoryCategory @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  sku         String? @unique
  material    String?
  tags        String[]          @default([])

  metadata Json? // { "designer": "XYZ", "width": "60inch" }

  // Visuals
  colorHex  String?
  colorName String?
  images    Json?   @default("{}")

  // Pricing & Stock
  price             Decimal @db.Decimal(10, 2)
  stockQuantity     Decimal @db.Decimal(10, 2)
  lowStockThreshold Decimal @default(10)

  isActive Boolean @default(true)

  // 👇 SOCIAL FEATURES FOR PHYSICAL ITEMS
  viewsCount  Int @default(0)
  likesCount  Int @default(0)
  
  // Relation for Likes
  likes       InventoryItemLike[]

  auditLogs  InventoryAuditLog[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fabricProfile   FabricProfile?

  embellishmentOptions EmbellishmentOption[]

  @@map("inventory_items")
}

model FabricProfile {
  id                     String        @id @default(uuid())
  
  inventoryItemId        String        @unique @map("inventory_item_id")
  inventoryItem          InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  
  // 🎨 Showroom (3D Tool) ka data
  textureUrl             String        @db.Text
  physicalRepeatWidthCm  Float
  physicalRepeatHeightCm Float
  
  patternOrigin          Json          
  
  // =====================================
  // 🚀 NAYE ADDITIONS FOR FRONTEND JSON
  // =====================================
  fabricType             String?       @map("fabric_type") // For "3 piece" etc.
  colors                 Json?         // { "primary": "#...", "accent": "#..." }
  textureParts           Json?         @map("texture_parts") // { "sleeves": { "texture_url": "...", ... } }
  // =====================================
  
  isPremium              Boolean       @default(false)
  premiumPrice           Float         @default(0.00)

  createdAt              DateTime      @default(now()) @db.Timestamptz
  updatedAt              DateTime      @updatedAt @db.Timestamptz

  @@map("fabric_profiles")
}

model InventoryAuditLog {
  id     String        @id @default(uuid())
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id])

  // Fixed: Admin relation linked correctly to User table
  adminId String @map("admin_id") @db.Uuid
  admin   User   @relation(fields: [adminId], references: [user_id])

  action         AuditAction
  quantityChange Decimal?
  reason         String?
  previousValues Json?

  createdAt DateTime @default(now())

  @@map("inventory_audit_logs")
}

// ==========================================
// 3. ORDER & CART MODELS
// ==========================================

model UserAddress {
  id           String   @id @default(uuid())
  user_id      String?  @db.Uuid
  label        String?
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  province     String?
  postalCode   String?
  country      String   @default("Pakistan")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relation
  user User? @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_addresses")
}

model Order {
  id                  String  @id @default(uuid())
  readableId          String? @unique
  user_id             String? @db.Uuid // Type match fix
  guestId             String?
  // Checkout Snapshots
  shippingAddressData Json?
  contactDetails      Json?
  isContactVerified   Boolean @default(false)

  // Financials
  currency       String @default("PKR")
  subtotal       Float  @default(0.00)
  taxAmount      Float  @default(0.00)
  shippingCost   Float  @default(0.00)
  discountAmount Float  @default(0.00)
  totalAmount    Float  @default(0.00)

  // Status
  operationalStatus OperationalStatus @default(checkout_draft)
  paymentStatus     PaymentStatus     @default(unpaid)
  paymentMethod     PaymentMethod?

  // Logistics
  courierName       String?
  trackingNumber    String?
  estimatedDelivery DateTime?

  // Timestamps
  placedAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user           User?           @relation(fields: [user_id], references: [user_id], onDelete: SetNull)
  items          OrderItem[]
  timelineEvents OrderTimeline[]

  @@map("orders")
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String

  itemType        ItemType
  inventoryItemId String?
  designId        String?

  // Frozen Details
  nameAtPurchase String
  quantity       Float
  unitPrice      Float
  totalLinePrice Float

  attributes Json?

  // Relations
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@map("order_items")
}

model OrderTimeline {
  id      Int    @id @default(autoincrement())
  orderId String

  statusFrom  OperationalStatus?
  statusTo    OperationalStatus?
  description String
  actorName   String?

  createdAt DateTime @default(now())

  // Relation
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_timeline")
}

// ==========================================
// 4. SIZING MODULE
// ==========================================

model StandardSize {
  id       Int    @id @default(autoincrement()) @map("size_id")
  sizeCode String @unique @db.VarChar(10) // 'XS', 'S', 'M', 'L'
  label    String @db.VarChar(50) // "Medium (Standard)"

  // JSONB constraints for flexibility
  recommendations Json? @default("{}") // { "height_min": 160, "weight_max_kg": 60 }
  measurements    Json // { "chest": 38, "waist": 32, "length": 42 }

  displayOrder Int     @default(0) // Sorting ke liye
  isActive     Boolean @default(true)

  // Relations
  profiles UserSizingProfile[]

  @@map("standard_sizes")
}

model UserSizingProfile {
  id     String @id @default(uuid()) @map("profile_id")
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  profileNickname String       @db.VarChar(50) // "My Eid Fit"
  method          SizingMethod // 'Standard_Preset' or 'Jute_Fit_Custom'

  // Standard Size (Agar user preset select kare)
  standardSizeId Int?
  standardSize   StandardSize? @relation(fields: [standardSizeId], references: [id])

  // Custom Size (Agar user Jute Fit use kare)
  customMeasurements Json? // { "unit": "Inches", "chest": 36, "waist": 28 ... }

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("user_sizing_profiles")
}

// ==========================================
// 🎨 DESIGN TOOL: NECKLINE CATEGORIES (Parent)
// ==========================================
model NecklineCategory {
  categoryId    String           @id @default(uuid()) @map("category_id")
  frontendId    String?          @unique @map("frontend_id") 
  
  name          String           // e.g., "Ban"
  family        String           // e.g., "Classic Ban"
  image         String[]         // Cloudinary URL array
  
  options       NecklineOption[] // Relation to options

  // Sorting Order Field
  sortOrder     Int              @default(0)

  createdAt     DateTime         @default(now()) @db.Timestamptz
  updatedAt     DateTime         @updatedAt @db.Timestamptz

  @@map("neckline_categories")
}

// ==========================================
// 🎨 DESIGN TOOL: NECKLINE OPTIONS (Child)
// ==========================================
model NecklineOption {
  optionId      String           @id @default(uuid()) @map("option_id")
  frontendId    String?          @map("frontend_id") 
  
  name          String           // e.g., "Straight Ban"
  
  // 🔘 Neckline Specific Toggles
  hasButtons    Boolean          @default(false)
  
  // 🖼️ Media & Data
  images        String[]         // Cloudinary URL array
  keywords      String[] 
  tags          String[] 
  layers        Json     

  // 💰 Pricing
  isPremium     Boolean          @default(false) @map("premium")
  premiumPrice  Float?           @map("premium_price")

  // 🔗 Relation: Yeh option kis category ka hissa hai?
  categoryId    String           @map("category_id")
  category      NecklineCategory @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)

  // Sorting Order Field
  sortOrder     Int              @default(0)

  createdAt     DateTime         @default(now()) @db.Timestamptz
  updatedAt     DateTime         @updatedAt @db.Timestamptz

  @@map("neckline_options")
}


// ==========================================
// 🎨 DESIGN TOOL: SLEEVE CATEGORIES (Parent)
// ==========================================
model SleeveCategory {
  categoryId    String         @id @default(uuid()) @map("category_id")
  frontendId    String?        @unique @map("frontend_id") 
  name          String
  image         String[]       
  options       SleeveOption[] 

  // Sorting Order Field
  sortOrder     Int            @default(0)

  createdAt     DateTime       @default(now()) @db.Timestamptz
  updatedAt     DateTime       @updatedAt @db.Timestamptz

  @@map("sleeve_categories")
}

// ==========================================
// 🎨 DESIGN TOOL: SLEEVE OPTIONS (Child)
// ==========================================
model SleeveOption {
  optionId      String         @id @default(uuid()) @map("option_id")
  frontendId    String?        @map("frontend_id") 
  name          String
  hasButtons    Boolean        @default(false)
  images        String[]       
  keywords      String[] 
  tags          String[] 
  layers        Json     
  isPremium     Boolean        @default(false) @map("premium")
  premiumPrice  Float?         @map("premium_price")
  categoryId    String         @map("category_id")
  category      SleeveCategory @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)

  // Sorting Order Field
  sortOrder     Int            @default(0)

  createdAt     DateTime       @default(now()) @db.Timestamptz
  updatedAt     DateTime       @updatedAt @db.Timestamptz

  @@map("sleeve_options")
}


// ==========================================
// 🎨 DESIGN TOOL: HEMLINE CATEGORIES (Parent)
// ==========================================
model HemlineCategory {
  categoryId    String          @id @default(uuid()) @map("category_id")
  frontendId    String?         @unique @map("frontend_id") 
  
  name          String          // e.g., "Short"
  image         String[]        // Cloudinary URL array (Category Thumbnail)
  
  options       HemlineOption[] // Relation to options

  // Sorting Order Field
  sortOrder     Int             @default(0)

  createdAt     DateTime        @default(now()) @db.Timestamptz
  updatedAt     DateTime        @updatedAt @db.Timestamptz

  @@map("hemline_categories")
}

// ==========================================
// 🎨 DESIGN TOOL: HEMLINE OPTIONS (Child)
// ==========================================
model HemlineOption {
  optionId      String          @id @default(uuid()) @map("option_id")
  frontendId    String?         @map("frontend_id") 
  
  name          String          // e.g., "Round"
  shapeTag      String?         // e.g., "round", "square"
  
  // 🖼️ Media & Data (Images & Keywords hat gaye hain)
  image         String[]        // Style thumbnail image(s)
  tags          String[] 
  layers        Json            // Isme jo SVGs aayengi wo Cloudinary se hongi
  
  // 💰 Pricing
  isPremium     Boolean         @default(false) @map("premium")
  premiumPrice  Float?          @map("premium_price")

  // 🔗 Relation: Yeh option kis category ka hissa hai?
  categoryId    String          @map("category_id")
  category      HemlineCategory @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)

  // Sorting Order Field
  sortOrder     Int             @default(0)

  createdAt     DateTime        @default(now()) @db.Timestamptz
  updatedAt     DateTime        @updatedAt @db.Timestamptz

  @@map("hemline_options")
}


// ==========================================
// 🎨 DESIGN TOOL: SIDE SLITS (Single Table)
// ==========================================
model SideSlit {
  sideSlitId            String    @id @default(uuid()) @map("side_slit_id")
  frontendId            String?   @unique @map("frontend_id") 
  
  name                  String    // e.g., "Regular"
  
  // 🖼️ Media & Data fields (Purani cheezein barqarar hain)
  image                 String[]  // Main thumbnail (array for consistency)
  images                String[]  // Additional option images
  keywords              String[]  
  tags                  String[]  

  // ✂️ Side Slit Specific Fields
  allowedHemlineShapes  String[]  // e.g., ["square", "round"]
  cutouts               Json      // 🐙 The nested magic JSON for SVGs

  // Sorting Order Field
  sortOrder             Int       @default(0)
  
  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @updatedAt @db.Timestamptz

  @@map("side_slits")
}


// ==========================================
// ✨ DESIGN TOOL: EMBELLISHMENTS (Categories & Options)
// ==========================================

model EmbellishmentCategory {
  categoryId  String                @id @default(uuid()) @map("category_id")
  frontendId  String?               @unique @map("frontend_id") // e.g., emb-plain
  
  name        String                // e.g., "Plain (No Embroidery)"
  image       String[]              // Main thumbnail
  
  // Relation to Options
  options     EmbellishmentOption[]

  // Sorting Order Field
  sortOrder   Int                   @default(0)
  
  createdAt   DateTime              @default(now()) @db.Timestamptz
  updatedAt   DateTime              @updatedAt @db.Timestamptz

  @@map("embellishment_categories")
}

model EmbellishmentOption {
  optionId          String                @id @default(uuid()) @map("option_id")
  frontendId        String?               @unique @map("frontend_id") // e.g., emb-elegance-floral
  
  // Foreign Key
  categoryId        String                @map("category_id")
  category          EmbellishmentCategory @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)

  // 🔗 Godown-to-Showroom Link
  inventoryItemId   String?        @map("inventory_item_id")
  inventoryItem     InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  
  name              String                // e.g., "Floral Border"
  images            String[]              // Additional gallery images
  
  premium           Boolean               @default(false)
  premiumPrice      Float?                @map("premium_price")
  
  keywords          String[]
  tags              String[]
  
  // The Allowed Arrays
  allowedNecklines  String[]
  allowedHemlines   String[]
  allowedSleeves    String[]
  
  // JSON Fields for Complex Data
  colors            Json                  // [{ id, name, hex }]
  overlays          Json                  // 🐙 The nested magic JSON for SVG layers & zIndex
  
  // Sorting Order Field
  sortOrder         Int                   @default(0)

  createdAt         DateTime              @default(now()) @db.Timestamptz
  updatedAt         DateTime              @updatedAt @db.Timestamptz

  @@map("embellishment_options")
}


// ==========================================
// 🔘 DESIGN TOOL: BUTTON OPTIONS (Single Table)
// ==========================================

model ButtonOption {
  buttonId      String    @id @default(uuid()) @map("button_id")
  frontendId    String?   @unique @map("frontend_id") // e.g., btn-plastic
  
  name          String    // e.g., "Plastic", "Metal", "Wood"
  images        String[]  // Button preview/thumbnail images
  
  premium       Boolean   @default(false)
  premiumPrice  Float?    @map("premium_price") // Only applicable if premium is true
  
  colors        Json      // 🎨 JSON Array: [{ id: "plt-black", name: "Black", hex: "#1a1a1a" }]
  
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  @@map("button_options")
}


// ==================================================
// 🛒 E-COMMERCE: MASTER PRODUCT MODULE
// ==================================================

model Product {
  id                            String   @id @default(uuid())
  name                          String
  productCategoryId      String   @map("product_category_id")
  productCategory        ProductCategory @relation(fields: [productCategoryId], references: [productCategoryId])
  sortOrder                     Int      @default(0) @map("sort_order")
  pieceType                     String   @map("piece_type") // e.g., "3 piece"
  
  // Pricing & Status
  baseStitchingPrice            Float    @map("base_stitching_price")
  status                        String   @default("Draft") // "Draft" ya "Publish"
  
  // Media & Meta
  images                        Json?    @default("[]") // Array of image URLs
  thumbnails                    Json?    @default("[]")
  seasonTags                    Json?    @map("season_tags") @default("[]") // e.g., ["Summer", "Eid"]

  // ==================================================
  // 🎛️ ALLOWED CUSTOMIZATION OPTIONS (Admin Selected)
  // ==================================================
  // Yahan hum sirf child option IDs save kar rahe hain (String arrays)
  allowedFabricIds              String[] @map("allowed_fabric_ids")
  allowedNecklineOptionIds      String[] @map("allowed_neckline_option_ids")
  allowedSleeveOptionIds        String[] @map("allowed_sleeve_option_ids")
  allowedHemlineOptionIds       String[] @map("allowed_hemline_option_ids")
  allowedSideSlitIds            String[] @map("allowed_side_slit_ids")
  allowedEmbellishmentOptionIds String[] @map("allowed_embellishment_option_ids")

  // ==================================================
  // 🎨 DEFAULT DESIGN (Kameez pehli dafa kaisi dikhegi)
  // ==================================================
  // JSON format: { fabric: { option_1_id: "..." }, neckline: { ... } }
  defaultDesign                 Json     @map("default_design")
  
 fabricConsumption Decimal @default(2.5) @db.Decimal(4, 2) // Example: 2.5 meters

  savedDesigns  SavedDesign[]

  createdAt                     DateTime @default(now()) @db.Timestamptz
  updatedAt                     DateTime @updatedAt @db.Timestamptz
  deletedAt DateTime?

  @@map("products")
}


// ==================================================
// 🗂️ MASTER PRODUCT CATEGORIES
// ==================================================
model ProductCategory {
  productCategoryId String    @id @default(uuid()) @map("product_category_id")
  name              String    @unique // e.g., "Kameez", "Kurta", "Trouser"
  description       String?
  isActive          Boolean   @default(true)
  sortOrder         Int       @default(0) @map("sort_order")
  
  // Relation to Products
  products          Product[] 

  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz

  @@map("product_categories")
}

model SavedDesign {
  saveDesignId  String   @id @default(uuid()) 
  
  // 1. User Relation (Fixed: Int se String @db.Uuid kar diya)
  userId        String   @db.Uuid      
  user          User     @relation(fields: [userId], references: [user_id]) 

  // 2. Base Product Relation (Fixed: Int se String kar diya)
  productId     String      
  product       Product  @relation(fields: [productId], references: [id])

  // 3. Design Details
  designName    String   @default("My Custom Design")
  thumbnailUrl  String?  
  canvasData    Json

  // 4. Status 
  status        String   @default("private")
  /// Admin: `false` = gallery/search mein nahi (published + inactive = hidden)
  isActive      Boolean  @default(true)
  basePrice        Float?
  addOnPrice       Float?
  finalPrice       Float?
  currency         String?  @default("PKR")
  pricingBreakdown Json?    // Array of objects save karne ke liye

  viewsCount    Int     @default(0)
  likesCount    Int     @default(0)
  remixesCount  Int     @default(0)
  remixedFromId String? // Agar kisi ne remix kiya, toh original design ki ID aayegi

  colors    Json?

  // Relation for Likes
  likes         DesignLike[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


// 👇 NAYA MODEL: Likes track karne ke liye
model DesignLike {
  id        String   @id @default(uuid())
  userId    String   // Jis user ne like kiya (iski type wahi rakhein jo SavedDesign mein userId ki hai)
  designId  String   // Jo design like hua
  createdAt DateTime @default(now())

  // Relation: Agar design delete ho toh uske likes bhi delete ho jayen
  design    SavedDesign @relation(fields: [designId], references: [saveDesignId], onDelete: Cascade)

  // 🚨 SMART CHECK: Ek user ek design ko sirf 1 dafa like kar sakta hai
  @@unique([userId, designId])
}


// 👇 NAYA MODEL: Inventory items ke likes track karne ke liye
model InventoryItemLike {
  id              String        @id @default(uuid())
  userId          String        @map("user_id") // Jis user ne like kiya
  inventoryItemId String        @map("inventory_item_id")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  // Ek user ek fabric ko sirf 1 baar like kar sake
  @@unique([userId, inventoryItemId])
  @@map("inventory_item_likes")
}

// Contact form submissions (user → admin inbox)
model ContactMessage {
  id        String   @id @default(uuid())
  subject   String // e.g. Design help, Order status
  name      String
  email     String
  message   String   @db.Text
  status    String   @default("UNREAD") // UNREAD, READ, RESOLVED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}