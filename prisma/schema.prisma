// prisma/schema.prisma

// 1. Ye block batata hai ke Node.js client banana hai
generator client {
  provider = "prisma-client-js"
}

// 2. Ye batata hai ke Database kaunsa hai
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Registered
  Administrator
  Inventory_Manager
}

enum AuthProviderType {
  Email
  Mobile
  Google
  Microsoft
  Apple
  Facebook
}

enum AuthAttemptType {
  login
  register
  otp_verify
  email_verify
}

enum AuthStatus {
  success
  failed
  blocked
}

enum InventoryType {
  FABRIC
  EMBELLISHMENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STOCK_ADJUSTMENT
  STOCK_OVERRIDE
}

// ==========================================
// 2. AUTH MODELS (Module 03)
// ==========================================

model User {
  user_id           String    @id @default(uuid()) @db.Uuid
  first_name        String    @db.VarChar(50)
  last_name         String    @db.VarChar(50)
  email             String?   @unique @db.VarChar(255)
  mobile_number     String?   @unique @db.VarChar(20)
  password_hash     String?   @db.VarChar(255)
  
  // Verification Status
  is_email_verified Boolean   @default(false)
  is_mobile_verified Boolean  @default(false)
  
  // Role & Profile
  role              UserRole  @default(Registered)
  profile_picture_url String?
  preferred_language String   @default("English") @db.VarChar(10)
  
  // Security
  failed_login_attempts Int      @default(0)
  locked_until          DateTime? @db.Timestamptz
  
  // Timestamps
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz
  deleted_at        DateTime? @db.Timestamptz // Soft Delete
  
  // Relations
  social_identities SocialIdentity[]
  sessions          UserSession[]
  verification_codes VerificationCode[]

  @@map("users") // Database mein table ka naam 'users' hoga
}

model SocialIdentity {
  identity_id  String           @id @default(uuid()) @db.Uuid
  user_id      String           @db.Uuid
  provider     AuthProviderType
  provider_uid String           @db.VarChar(255)
  linked_at    DateTime         @default(now()) @db.Timestamptz
  
  user         User             @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([provider, provider_uid])
  @@map("social_identities")
}

model VerificationCode {
  code_id    String   @id @default(uuid()) @db.Uuid
  identifier String   @db.VarChar(255) // Email or Mobile
  code       String   @db.VarChar(10)
  type       String   @db.VarChar(20)  // 'email_verify', 'mobile_otp'
  expires_at DateTime @db.Timestamptz
  is_used    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz


   user_id    String?   @db.Uuid
   user       User?     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  @@map("verification_codes")
}

model UserSession {
  session_id         String   @id @default(uuid()) @db.Uuid
  user_id            String   @db.Uuid
  refresh_token_hash String   @db.VarChar(255)
  device_info        String?
  ip_address         String?  @db.Inet
  expires_at         DateTime @db.Timestamptz
  last_active        DateTime @default(now()) @db.Timestamptz
  
  user               User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_sessions")
}


model AuthAuditLog {
  id             BigInt          @id @default(autoincrement()) // SQL: BIGINT AUTO_INCREMENT
  identifier     String          @db.VarChar(255)              // Email/Phone
  attempt_type   AuthAttemptType                               // Enum mapping
  status         AuthStatus                                    // Enum mapping
  failure_reason String?         @db.VarChar(255)              // Nullable (Success hone pe null hoga)
  
  ip_address     String?         @db.VarChar(45)               // IPv6 support ke liye 45 length
  user_agent     String?         @db.Text                      // Browser/Device info
  created_at     DateTime        @default(now()) @db.Timestamptz

  @@map("auth_audit_logs")
}


// 1. Categories (e.g., "Silk", "Buttons", "Lawn") 
model InventoryCategory {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  type        InventoryType   // Fabric or Embellishment
  description String?
  items       InventoryItem[] // Relation: Ek category mein bohot items ho sakte hain
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("inventory_categories") // DB mein table ka naam ye hoga
}

// 2. Inventory Items (The actual stock) 
model InventoryItem {
  id                String            @id @default(uuid()) // UUID use kar rahe hain security ke liye
  categoryId        Int
  category          InventoryCategory @relation(fields: [categoryId], references: [id])
  
  name              String
  description       String?
  sku               String?           @unique // Stock Keeping Unit (Optional but pro)
  
  // Metadata fields (JSON best hai flexible data ke liye like Designer, Origin) 
  metadata          Json?             // { "designer": "XYZ", "width": "60inch", "shininess": "High" }
  
  // Visuals
  colorHex          String?           // e.g., #FF5733 
  colorName         String?           // e.g., "Royal Blue"
  images Json? @default("{}")

  // Pricing & Stock
  price             Decimal           @db.Decimal(10, 2) // Price kabhi float nahi hoti
  stockQuantity     Decimal           @db.Decimal(10, 2) // Fabric yards (decimal) aur Buttons units (int) dono handle karega 
  lowStockThreshold Decimal           @default(10)       // Alert level 
  
  isActive          Boolean           @default(true)
  
  auditLogs         InventoryAuditLog[] // Relation to logs
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("inventory_items")
}

// 3. Audit Logs (Security & Tracking) 
model InventoryAuditLog {
  id             String        @id @default(uuid())
  itemId         String
  item           InventoryItem @relation(fields: [itemId], references: [id])
  
  // Admin jisne change kiya (Make sure User model already exists in your schema)
  adminId        String        
  // admin          User          @relation(fields: [adminId], references: [id]) 
  // NOTE: Upar wali line uncomment karna agar User model define hai
  
  action         AuditAction   // CREATE, UPDATE, OVERRIDE
  quantityChange Decimal?      // Kitna stock add/remove hua
  reason         String?       // Kyun change kiya? (Justification) [cite: 57]
  previousValues Json?         // Purana data kya tha (Snapshot)
  
  createdAt      DateTime      @default(now())

  @@map("inventory_audit_logs")
}